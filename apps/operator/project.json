{
  "name": "operator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/operator/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/operator",
        "browser": "apps/operator/src/main.ts",
        "tsConfig": "apps/operator/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/operator/public"
          }
        ],
        "styles": [
          "apps/operator/src/styles.scss",
          "brands/theme.scss"
        ],
        "server": "apps/operator/src/main.server.ts",
        "ssr": {
          "entry": "apps/operator/src/server.ts"
        },
        "outputMode": "server"

      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "500kb",
              "maximumError": "1mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "4kb",
              "maximumError": "8kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        },

        "whitestar": {
          "fileReplacements": [

          ],
          "styles": [
            "apps/operator/src/styles.scss",
            "brands//whitestar/theme.scss"
          ]
        }
      },
      "defaultConfiguration": "development"
    },

    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "operator:build:production"
        },
        "development": {
          "buildTarget": "operator:build:development"
        },
        "whitestar": {
          "buildTarget": "operator:build:development,whitestar"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@angular/build:unit-test",
      "options": {
        "watch": false
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "operator:build",
        "port": 4200,
        "staticFilePath": "dist/apps/operator/browser",
        "spa": true
      }
    }
  }
}
